<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="26dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#E5E7EB" />

    <TextView
        android:id="@+id/tvOtpTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Verification Code"
        android:textColor="#111827"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvOtpSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="We have sent a 6 digit code to your number"
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <!-- IMPORTANT: This ID fixes your error -->
    <EditText
        android:id="@+id/etOtpInput"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="26dp"
        android:background="@android:drawable/edit_text"
        android:gravity="center"
        android:hint="- - - - - -"
        android:importantForAutofill="yes"
        android:inputType="number"
        android:letterSpacing="0.45"
        android:maxLength="6"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="#0B57D0"
        android:textColorHint="#9CA3AF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- IMPORTANT: This ID is used in LoginActivity -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerifyOtp"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="22dp"
        android:backgroundTint="#0B57D0"
        android:text="Verify &amp; Proceed"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="29dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- IMPORTANT: This ID is used in LoginActivity -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend code in 00:30"
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <!-- IMPORTANT: This ID is used in LoginActivity -->
        <TextView
            android:id="@+id/tvResendBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:padding="6dp"
            android:text="Resend"
            android:textColor="#0B57D0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- IMPORTANT: This ID is used in LoginActivity -->
    <ProgressBar
        android:id="@+id/progressOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:visibility="gone" />

</LinearLayout>