<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_top_wave"
    android:backgroundTint="#FFFFFF"
    android:orientation="vertical"
    android:padding="30dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="50dp"
        android:layout_height="5dp"
        android:background="#E0E0E0"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Verification Code"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="We have sent a code to your number"
        android:textColor="#666666" />

    <!-- Stylish OTP Box -->
    <EditText
        android:id="@+id/etOtpInput"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/ic_launcher_background"
        android:backgroundTint="#F5F7FA"
        android:gravity="center"
        android:hint="- - - -"
        android:inputType="number"
        android:letterSpacing="1.2"
        android:maxLength="6"
        android:textColor="#0056D2"
        android:textSize="28sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerifyOtp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#0056D2"
        android:text="Verify &amp; Proceed"
        android:textStyle="bold"
        app:cornerRadius="30dp" />

    <!-- Timer & Resend Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend code in 00:30"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tvResendBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend"
            android:textColor="#0056D2"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

</LinearLayout>